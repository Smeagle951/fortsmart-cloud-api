{
  "name": "fortsmart-cloud-api",
  "version": "1.0.0",
  "private": true,
  "description": "FortSmart Cloud API — sync base, Railway + PostgreSQL (Neon)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-migrations.mjs",
    "start": "node dist/server.js",
    "dev": "node --import tsx src/server.ts",
    "migrate": "node --import tsx src/db/migrate.ts",
    "migrate:prod": "node dist/db/migrate.js",
    "hash-api-key": "node scripts/generate-api-key-hash.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.758.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.1",
    "@types/pg": "^8.11.10",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "helmet": "^7.1.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.1",
    "typescript": "^5.7.2"
  },
  "devDependencies": {
    "tsx": "^4.19.2"
  }
}