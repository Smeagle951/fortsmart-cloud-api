# PostgreSQL (Neon, DigitalOcean, local)
DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Se migrate falhar na cloud com erro TLS, force SSL explícito: DATABASE_SSL=1
# Para desativar heurística (ex.: rede interna): DATABASE_SSL=0

# Salt/pepper para SHA-256 da API key (nunca commitar o valor real)
API_KEY_PEPPER=change-me-in-production

# Porta HTTP (Railway injeta PORT)
PORT=3000

# Opcional: simula dry-run em POST /sync/base/push?dryRun=true (rollback após processar)
# DRY_RUN=1

# --- Cloudflare R2 (bucket recomendado: fortsmart-media) ---
# Use FORTSMART_S3_* OU R2_* (o código aceita ambos; nomes abaixo são os preferidos no Railway).
#
# R2_ACCOUNT_ID=<id da conta Cloudflare (painel direito)>
# R2_ACCESS_KEY_ID=<token R2 — S3 API Access Key>
# R2_SECRET_ACCESS_KEY=<token R2 — S3 API Secret>
# R2_BUCKET_NAME=fortsmart-media
# R2_ENDPOINT=https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
# R2_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev
#
# Equivalentes FORTSMART (mesmos valores; útil se já usa prefixo FORTSMART no Railway):
# FORTSMART_S3_ENDPOINT=https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
# FORTSMART_S3_REGION=auto
# FORTSMART_S3_ACCESS_KEY=<mesmo que R2_ACCESS_KEY_ID>
# FORTSMART_S3_SECRET_KEY=<mesmo que R2_SECRET_ACCESS_KEY>
# FORTSMART_S3_BUCKET=fortsmart-media
# FORTSMART_S3_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev
#
# CORS do bucket: cole scripts/r2-cors.json no painel R2 → bucket → Settings → CORS
# URL pública: R2 → bucket → Settings → Public access (subdomínio r2.dev ou domínio custom)
#
# Lifecycle (3 dias): configure no painel do R2 (Object lifecycle) com prefixos
# */talhao/*/monitoring/* e */talhao/*/planting/*

# --- Copernicus Data Space (NDVI — somente no servidor, nunca no app) ---
# CDSE_CLIENT_ID=
# CDSE_CLIENT_SECRET=
# CDSE_TOKEN_URL=https://identity.dataspace.copernicus.eu/auth/realms/CDSE/protocol/openid-connect/token
# SENTINEL_CATALOG_URL=https://sh.dataspace.copernicus.eu/api/v1/catalog/search
# SENTINEL_PROCESS_URL=https://sh.dataspace.copernicus.eu/api/v1/process
# NDVI_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev
# NDVI_DEV_MOCK=true
