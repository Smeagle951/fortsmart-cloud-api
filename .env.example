# PostgreSQL (Neon, DigitalOcean, local)
DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Se migrate falhar na cloud com erro TLS, force SSL explícito: DATABASE_SSL=1
# Para desativar heurística (ex.: rede interna): DATABASE_SSL=0

# Salt/pepper para SHA-256 da API key (nunca commitar o valor real)
API_KEY_PEPPER=change-me-in-production

# Porta HTTP (Railway injeta PORT)
PORT=3000

# Opcional: simula dry-run em POST /sync/base/push?dryRun=true (rollback após processar)
# DRY_RUN=1

# Object storage (S3-compatible / Cloudflare R2) — upload temporário de imagens de monitoramento (~3 dias via lifecycle no bucket)
# FORTSMART_S3_* ou R2_* (ambos aceitos pelo código)
# FORTSMART_S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# FORTSMART_S3_REGION=auto
# FORTSMART_S3_ACCESS_KEY_ID=
# FORTSMART_S3_SECRET_ACCESS_KEY=
# FORTSMART_S3_BUCKET=fortsmart-temp-images
# URL pública do bucket (Custom Domain / R2 public URL) — usada em cloud_url retornado ao cliente
# FORTSMART_S3_PUBLIC_BASE_URL=https://img.seudominio.com
#
# Lifecycle (3 dias): configure no painel do R2 (Object lifecycle) ou regra S3 equivalente
# com prefixo opcional "*/talhao/*/monitoring/*" para expirar/apagar objetos após 3 dias.
