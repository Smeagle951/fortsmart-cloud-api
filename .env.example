# PostgreSQL (Neon, DigitalOcean, local)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Salt/pepper para SHA-256 da API key (nunca commitar o valor real)
API_KEY_PEPPER=change-me-in-production

# Porta HTTP (Railway injeta PORT)
PORT=3000

# Opcional: simula dry-run em POST /sync/base/push?dryRun=true (rollback após processar)
# DRY_RUN=1
