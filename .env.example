# PostgreSQL (Neon — produção no Render)
DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Se migrate falhar na cloud com erro TLS, force SSL explícito: DATABASE_SSL=1
# Para desativar heurística (ex.: rede interna): DATABASE_SSL=0

# Salt/pepper para SHA-256 da API key (nunca commitar o valor real)
API_KEY_PEPPER=change-me-in-production

# Porta HTTP (Render injeta PORT automaticamente)
PORT=3000
NODE_ENV=production

# Opcional: simula dry-run em POST /sync/base/push?dryRun=true (rollback após processar)
# DRY_RUN=1

# Opcional: não rodar migrations no boot (rodar npm run migrate:prod manualmente)
# DISABLE_BOOT_MIGRATIONS=1

# URL pública devolvida no pairing (default: https://api.fortsmart-agro.com.br)
# PUBLIC_API_URL=https://api.fortsmart-agro.com.br

# --- Cloudflare R2 (bucket recomendado: fortsmart-media) ---
# Use FORTSMART_S3_* OU R2_* (o código aceita ambos).
#
# R2_ACCOUNT_ID=<id da conta Cloudflare>
# R2_ACCESS_KEY_ID=<token R2 — S3 API Access Key>
# R2_SECRET_ACCESS_KEY=<token R2 — S3 API Secret>
# R2_BUCKET_NAME=fortsmart-media
# R2_ENDPOINT=https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
# R2_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev
#
# Aliases na documentação de migração:
#   R2_BUCKET     → use R2_BUCKET_NAME
#   R2_PUBLIC_URL → use R2_PUBLIC_BASE_URL
#
# CORS_ORIGIN — não usado pelo Express atual (cors() aberto). Configurar só se
# o código passar a restringir origins no futuro.
#
# JWT_SECRET — não usado (auth via API key Bearer).

# --- Copernicus Data Space (NDVI — somente no servidor) ---
# CDSE_CLIENT_ID=
# CDSE_CLIENT_SECRET=
# CDSE_TOKEN_URL=https://identity.dataspace.copernicus.eu/auth/realms/CDSE/protocol/openid-connect/token
# SENTINEL_CATALOG_URL=https://stac.dataspace.copernicus.eu/v1/search
# SENTINEL_PROCESS_URL=https://sh.dataspace.copernicus.eu/api/v1/process
# NDVI_PUBLIC_BASE_URL=https://pub-xxxx.r2.dev
# NDVI_DEV_MOCK=true
# NDVI_PROVIDER=copernicus

# --- Google Earth Engine (desativado por padrão) ---
# Copernicus Sentinel-2 L2A é o provider principal. GEE fica dormente para
# evitar custo acidental, mesmo se existirem credenciais antigas no Railway.
# Uso recomendado: manter /generate em Copernicus e usar GEE no pacote avançado:
# NDVI_PROVIDER=copernicus
# NDVI_PACKAGE_PROVIDER=gee
# GEE_ALLOW_USAGE=true
# Para usar GEE como provider global:
# NDVI_PROVIDER=gee
# GEE_ALLOW_USAGE=true
# GEE_ENABLED=true # opcional; use false para bloquear mesmo com GEE_ALLOW_USAGE
# Diagnóstico: GET /api/soil-sampling/ndvi/gee-health
# GEE_ENABLED=false
# GEE_ALLOW_USAGE=false
# GEE_PROJECT_ID=
# GEE_CLIENT_EMAIL=
# Chave privada PEM (use \n literais para quebras de linha):
# GEE_PRIVATE_KEY=
# Alternativa: cole o JSON inteiro da conta de serviço (substitui email+chave):
# GEE_SERVICE_ACCOUNT_JSON=
# Tunables opcionais do render GEE:
# GEE_THUMB_SIZE=768
# GEE_PACKAGE_THUMB_SIZE=1024
# GEE_PACKAGE_RENDER_CONCURRENCY=4
# GEE_MAX_CLOUD=35
